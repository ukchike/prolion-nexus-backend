# Copy to .env and fill in.

PORT=4000

# Your deployed frontend URL (Vercel), used for CORS in production.
# Leave blank while developing locally — localhost origins are
# already allowed by default in src/server.js.
FRONTEND_URL=https://your-nexus-app.vercel.app

# Get this from console.groq.com — required for Sprint 2's
# /api/categorise-transactions endpoint. Without it, that endpoint
# returns a clear error rather than failing silently.
GROQ_API_KEY=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

# Which AI provider to use for categorisation: 'groq' (default) or
# 'groq'. Groq is free (no card required) — useful while your Anthropic
# account has no funded credits. Switching back later is just changing
# this value, no code changes needed.
AI_PROVIDER=groq

# Only needed if AI_PROVIDER=groq. Get a free key from console.groq.com.
GROQ_API_KEY=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
