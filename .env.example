PORT=4000
FRONTEND_URL=https://your-nexus-app.vercel.app

# AI Provider Configuration
# 'anthropic' (default) or 'groq' (free, console.groq.com)
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Supabase Configuration (used only to verify the caller's session JWT —
# see middleware/requireAuth.js; this service never queries the database)
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_ANON_KEY=eyJhbGc...
